# Fynesse Framework Repository .gitignore
#
# This is the FRAMEWORK repo, not a consumer project.
# Many files that VibeSafe excludes in consumer projects are committed content here.

# ── Runtime / build artifacts ──────────────────────────────────────────────
.venv-vibesafe/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── OS artifacts ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor artifacts ───────────────────────────────────────────────────────
*.code-workspace~
.idea/
*.swp

# ── Generated / derived files (regenerated by scripts) ─────────────────────
# backlog/index.md is regenerated by update_index.py — still useful to commit
# tenets combined files are regenerated — still useful to commit

# ── Machine-specific config (never commit credentials or local paths) ───────

# BEGIN fynesse
# Machine-specific Fynesse config — managed by install.sh, do not commit.
fynesse/machine.yml
# END fynesse
